# Copy to .env and fill with your own credentials. Never commit the real .env file.
OPENAI_API_KEY=YOUR_OPENAI_KEY
EXECUTION_MODE=simulate
PAPER_EXECUTE=0
MAX_QTY_CAP=200

# --- IBKR Client Portal / Socket ---
IBKR_BASE_URL=https://localhost:5003/v1/api
IBKR_ACCOUNT_ID=YOUR_IBKR_PAPER_ACCOUNT
IBKR_SOCKET_HOST=127.0.0.1
IBKR_SOCKET_PORT=7497

# --- OANDA Practice ---
OANDA_BASE_URL=https://api-fxpractice.oanda.com
OANDA_API_KEY=YOUR_OANDA_PRACTICE_KEY
OANDA_ACCOUNT_ID=YOUR_OANDA_PRACTICE_ACCOUNT

# --- Alpaca Paper ---
APCA_API_KEY_ID=YOUR_ALPACA_PAPER_KEY
APCA_API_SECRET_KEY=YOUR_ALPACA_PAPER_SECRET
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# --- Tradier Sandbox ---
TRADIER_BASE_URL=https://sandbox.tradier.com/v1
TRADIER_API_KEY=YOUR_TRADIER_SANDBOX_KEY
TRADIER_ACCOUNT_ID=YOUR_TRADIER_SANDBOX_ACCOUNT

# --- News Providers ---
FINNHUB_API_KEY=YOUR_FINNHUB_KEY
SERPAPI_API_KEY=YOUR_SERPAPI_KEY

# --- Position Monitor ---
POSITION_DB_PATH=positions.db
MONITOR_INTERVAL_SECONDS=60

# --- Account ---
ACCOUNT_SIZE=100000
MAX_RISK_PER_TRADE=0.01
BROKER_PREFERENCE=ibkr

# --- Scheduler ---
SCHEDULER_MARKETS=US
SCHEDULER_UNIVERSE=sp500
SCHEDULER_TIMEFRAME=1D
SCHEDULER_AUTO_EXECUTE=0
SCHEDULER_FLATTEN_INTRADAY=0
SCANNER_MAX_WORKERS=4
TRAILING_STOP_ATR_MULT=2.0
MAX_POSITIONS_PER_SECTOR=2

# --- Backtesting ---
BACKTEST_ENABLED=1
BACKTEST_HOUR=21
BACKTEST_MINUTE=0
BACKTEST_SYMBOLS=AAPL,MSFT,GOOGL,NVDA,TSLA
